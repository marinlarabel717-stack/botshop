# 库存真实根目录（代理 clone 运行时强烈建议配置）
# 主号铺协议号目录，例如：/www/wwwroot/bot/botshop/协议号
BASE_PROTOCOL_PATH=
# 主号铺直登号目录，例如：/www/wwwroot/bot/botshop/号包
# 不填时会尝试按 BASE_PROTOCOL_PATH 的同级目录自动推导 /号包
BASE_ACCOUNT_BAG_PATH=
