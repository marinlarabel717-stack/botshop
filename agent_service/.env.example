# 代理分销服务骨架配置
AGENT_BOT_ID=agent_demo
AGENT_BOT_TOKEN=
AGENT_NAME=代理分销演示店
AGENT_USERNAME=
AGENT_CUSTOMER_SERVICE=@support
AGENT_DEFAULT_LANG=zh
AGENT_ADMIN_IDS=
AGENT_TRC20_ADDRESS=
