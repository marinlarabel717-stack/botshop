# 上传机器人自己的 Bot Token
UPLOAD_BOT_TOKEN=替换成上传机器人的Token

# 允许使用上传机器人的管理员 Telegram ID，多个用英文逗号分隔
UPLOAD_ADMIN_USER_IDS=5991190607

# 号铺主机器人 Token（用于发送补货通知；格式复用 botshop 原逻辑）
STORE_BOT_TOKEN=替换成号铺机器人的Token

# MongoDB 配置（应指向 botshop 正在使用的同一套库）
# 如果这里留空，脚本会先继承 botshop 根目录 .env 里的 Mongo 配置；
# 你也可以在这里单独覆盖成另一套。
MONGO_URI=mongodb://127.0.0.1:27018/
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_DB=admin
MONGO_DB_NAME=999bot
MONGO_CHAIN_DB_NAME=999bot

# 多候选商品按钮每页显示多少条
UPLOAD_CANDIDATE_PAGE_SIZE=8
