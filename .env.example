# Telegram BotFather 里拿到的机器人 Token
BOT_TOKEN=替换成你的TelegramBotToken

# 管理员 Telegram ID，多个用英文逗号分隔
ADMIN_USER_IDS=5991190607

# MongoDB 配置（当前默认使用你新开的 27018 无密码实例）
MONGO_URI=mongodb://127.0.0.1:27018/
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_DB=admin
MONGO_DB_NAME=999bot
MONGO_CHAIN_DB_NAME=999bot

# OKPay 商户配置
OKPAY_API_URL=https://api.okaypay.me/shop/
OKPAY_SHOP_ID=替换成你的OKPay商户ID
OKPAY_SHOP_TOKEN=替换成你的OKPay商户Token
OKPAY_NAME=号铺
OKPAY_BOT_USERNAME=你的机器人用户名不带@

# 充值入口显示开关（true=显示，false=隐藏）
SHOW_TRC20_RECHARGE_ENTRY=true
SHOW_OKPAY_RECHARGE_ENTRY=true

# 一键克隆 Bot 配置（可选）
BOT_CLONE_ROOT=/www/wwwroot/botshop-clones
BOT_CLONE_REPO_URL=https://github.com/marinlarabel717-stack/botshop.git

# OKPay 回调配置
# 这个地址要填到 OKPay 订单里，必须是公网可访问地址，例如：https://你的域名/okpay/callback
OKPAY_CALLBACK_URL=https://你的域名/okpay/callback
# 本机监听端口；如果用 Nginx/宝塔反代，把公网 /okpay/callback 转发到 http://127.0.0.1:8088
OKPAY_CALLBACK_HOST=0.0.0.0
OKPAY_CALLBACK_PORT=8088

# TronGrid / TRC20 自动到账监听配置
# TronGrid 现在强烈依赖 API Key；去控制台申请后填这里
TRONGRID_API_BASE=https://api.trongrid.io/v1
TRONGRID_API_KEY=
# TRC20 USDT 合约地址（主网默认这个）
TRC20_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# 监听轮询秒数（想更实时可设 3；太低会更吃 API 配额）
TRONGRID_POLL_SECONDS=3
# 首次启动向前回看分钟数
TRONGRID_LOOKBACK_MINUTES=30
# 可选：手动指定多个监听地址，英文逗号分隔；不填则默认读取数据库里“充值地址”
TRONGRID_MONITOR_ADDRESSES=
