# Telegram BotFather 里拿到的机器人 Token
BOT_TOKEN=替换成你的TelegramBotToken

# 管理员 Telegram ID，多个用英文逗号分隔
ADMIN_USER_IDS=5991190607

# MongoDB 配置（当前默认使用你新开的 27018 无密码实例）
MONGO_URI=mongodb://127.0.0.1:27018/
MONGO_USER=
MONGO_PASSWORD=
MONGO_AUTH_DB=admin
MONGO_DB_NAME=999bot
MONGO_CHAIN_DB_NAME=999bot

# OKPay 商户配置
OKPAY_API_URL=https://api.okaypay.me/shop/
OKPAY_SHOP_ID=替换成你的OKPay商户ID
OKPAY_SHOP_TOKEN=替换成你的OKPay商户Token
OKPAY_NAME=号铺
OKPAY_BOT_USERNAME=你的机器人用户名不带@

# OKPay 回调配置
# 这个地址要填到 OKPay 订单里，必须是公网可访问地址，例如：https://你的域名/okpay/callback
OKPAY_CALLBACK_URL=https://你的域名/okpay/callback
# 本机监听端口；如果用 Nginx/宝塔反代，把公网 /okpay/callback 转发到 http://127.0.0.1:8088
OKPAY_CALLBACK_HOST=0.0.0.0
OKPAY_CALLBACK_PORT=8088
